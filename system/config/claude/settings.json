{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Glob",
      "Grep",
      "Agent",
      "Edit(/.claude/skills/spec/**)",
      "Edit(/.claude/skills/onboard/**)",
      "Edit(/.claude/skills/press/**)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/export-transcript.sh"
          }
        ]
      }
    ]
  }
}
